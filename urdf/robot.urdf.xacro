<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot_vacuum">

    <material name="purple">
        <color rgba="0.53 0.36 1.0 1.0"/>
    </material>

    <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
    </material>

    <material name="gray">
        <color rgba="0.4 0.4 0.4 1.0"/>
    </material>

    <link name="base_footprint"/>

    <link name="base_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.175" length="0.09"/>
            </geometry>
            <material name="purple"/>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.175" length="0.09"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.5" radius="0.175" length="0.09" xyz="0 0 0" rpy="0 0 0"/>
    </link>

    <joint name="footprint_joint" type="fixed">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

    <xacro:macro name = "wheel_link" params = "prefix">
        <link name="${prefix}_wheel">
            <visual>
                <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
                <geometry>
                    <cylinder radius="0.03" length="0.01"/>
                </geometry>
                <material name="black"/>
            </visual>
            <collision>
                <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
                <geometry>
                    <cylinder radius="0.03" length="0.01"/>
                </geometry>
            </collision>
            <xacro:inertial_cylinder mass="0.2" radius="0.03" length="0.01" xyz="0 0 0" rpy="0 0 0"/>
        </link>
    </xacro:macro>

    <xacro:wheel_link prefix = "right"/>
    <xacro:wheel_link prefix = "left"/>

    <xacro:macro name = "wheel_joint" params = "prefix y">
        <joint name="${prefix}_wheel_joint" type="continuous">
            <origin xyz="0.0 ${y} -0.045" rpy="0.0 0.0 0.0"/>
            <parent link="base_link"/>
            <child link="${prefix}_wheel"/>
            <axis xyz="0.0 1.0 0.0"/>
        </joint>
    </xacro:macro>

    <xacro:wheel_joint prefix = "right" y = "-0.18"/>
    <xacro:wheel_joint prefix = "left" y = "0.18"/> 

    <xacro:macro name = "caster_wheel" params = "side">
        <link name="${side}_caster_wheel">
            <visual>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <geometry>
                    <sphere radius="0.015"/>
                </geometry>
                <material name="black"/>
            </visual>
            <collision>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <geometry>
                    <sphere radius="0.015"/>
                </geometry>
            </collision>
            <inertial_sphere mass="0.05" radius="0.015" xyz="0 0 0" rpy="0 0 0"/>
        </link>
    </xacro:macro>

    <xacro:caster_wheel side = "front"/>
    <xacro:caster_wheel side = "back"/>

    <xacro:macro name = "caster_wheel_joint" params = "side x">
        <joint name="${side}_caster_wheel_joint" type="fixed">
            <origin xyz="${x} 0.0 -0.06" rpy="0.0 0.0 0.0"/>
            <parent link="base_link"/>
            <child link="${side}_caster_wheel"/>
        </joint>
    </xacro:macro>

    <xacro:caster_wheel_joint side = "front" x = "0.1"/>
    <xacro:caster_wheel_joint side = "back" x = "-0.1"/>

</robot>